# Opens LibreWolf
"librewolf"
    Mod4 + w

# Opens Spotify
"spotify"
    Mod4 + s

# Sets the volume
"dsetvolume"
    Mod4 + v

# Opens Brave
"brave"
    Mod4 + b

# Opens Krita
"krita"
    Mod4 + k

# Opens KeePassXC
"keepassxc"
    Mod4 + p

# Opens LibreOffice
"libreoffice"
    Mod4 + o

# Opens slalbums
"slalbums"
    Mod4 + a

# Opens sldocuments
"sldocuments"
    Mod4 + d
